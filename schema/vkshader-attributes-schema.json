{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/vk-custom-op-attrs.schema.json",
  "title": "Vulkan Shader in TOSA Custom Operation Attributes",
  "type": "object",
  "description": "Schema describing attributes for embedding a Vulkan shader inside a TOSA custom operation. This includes entry point definition, workgroup configuration, shader source or binary (SPIR-V), and Vulkan resource binding metadata.",
  "$defs": {
    "sampler_config": {
      "type": "object",
      "description": "Optional sampler configuration for a sampled image resource. If present, all sampler fields are required.",
      "properties": {
        "min_filter": {
          "type": "string",
          "enum": [
            "VK_FILTER_NEAREST",
            "VK_FILTER_LINEAR",
            "VK_FILTER_CUBIC_IMG"
          ],
          "description": "Sampler minification filter."
        },
        "mag_filter": {
          "type": "string",
          "enum": [
            "VK_FILTER_NEAREST",
            "VK_FILTER_LINEAR",
            "VK_FILTER_CUBIC_IMG"
          ],
          "description": "Sampler magnification filter."
        },
        "address_mode_u": {
          "type": "string",
          "enum": [
            "VK_SAMPLER_ADDRESS_MODE_REPEAT",
            "VK_SAMPLER_ADDRESS_MODE_MIRRORED_REPEAT",
            "VK_SAMPLER_ADDRESS_MODE_CLAMP_TO_EDGE",
            "VK_SAMPLER_ADDRESS_MODE_CLAMP_TO_BORDER",
            "VK_SAMPLER_ADDRESS_MODE_MIRROR_CLAMP_TO_EDGE"
          ],
          "description": "Sampler address mode in the U dimension."
        },
        "address_mode_v": {
          "type": "string",
          "enum": [
            "VK_SAMPLER_ADDRESS_MODE_REPEAT",
            "VK_SAMPLER_ADDRESS_MODE_MIRRORED_REPEAT",
            "VK_SAMPLER_ADDRESS_MODE_CLAMP_TO_EDGE",
            "VK_SAMPLER_ADDRESS_MODE_CLAMP_TO_BORDER",
            "VK_SAMPLER_ADDRESS_MODE_MIRROR_CLAMP_TO_EDGE"
          ],
          "description": "Sampler address mode in the V dimension."
        },
        "border_color": {
          "type": "string",
          "enum": [
            "VK_BORDER_COLOR_FLOAT_TRANSPARENT_BLACK",
            "VK_BORDER_COLOR_INT_TRANSPARENT_BLACK",
            "VK_BORDER_COLOR_FLOAT_OPAQUE_BLACK",
            "VK_BORDER_COLOR_INT_OPAQUE_BLACK",
            "VK_BORDER_COLOR_FLOAT_OPAQUE_WHITE",
            "VK_BORDER_COLOR_INT_OPAQUE_WHITE",
            "VK_BORDER_COLOR_FLOAT_CUSTOM_EXT",
            "VK_BORDER_COLOR_INT_CUSTOM_EXT"
          ],
          "description": "Sampler border color."
        }
      },
      "required": [
        "min_filter",
        "mag_filter",
        "address_mode_u",
        "address_mode_v",
        "border_color"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "entry_point": {
      "type": "string",
      "description": "Name of the shader's entry point."
    },
    "workgroup_sizes": {
      "type": "array",
      "description": "Workgroup size as [x, y, z].",
      "items": {
        "type": "integer",
        "minimum": 1
      },
      "minItems": 3,
      "maxItems": 3
    },
    "push_constants": {
      "type": "string",
      "description": "(Optional) Comma-separated list of \"key: size\" pairs representing push constant name and size in bytes (e.g. \"const1: 4, const2: 8\")."
    },
    "shader_language": {
      "type": "string",
      "enum": [
        "",
        "SPIR-V",
        "GLSL",
        "HLSL"
      ],
      "default": "",
      "description": "(Optional) Language used in shader_code."
    },
    "shader_code": {
      "type": "string",
      "default": "",
      "description": "(Optional) Shader code. Validation depends on shader_language."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "shader_language": {
            "const": "SPIR-V"
          }
        },
        "required": [
          "shader_language",
          "shader_code"
        ]
      },
      "then": {
        "properties": {
          "shader_code": {
            "type": "string",
            "contentEncoding": "base64",
            "description": "Base64-encoded SPIR-V binary blob."
          }
        }
      },
      "else": {
        "properties": {
          "shader_code": {
            "type": "string",
            "description": "Textual shader source (e.g. GLSL, HLSL)."
          }
        }
      }
    }
  ],
  "patternProperties": {
    "^(input|output)_(0|[1-9]\\d*)_vkformat$": {
      "type": "string",
      "description": "Vulkan format of the indexed input/output."
    },
    "^(input|output)_(0|[1-9]\\d*)_vkdescriptortype$": {
      "type": "string",
      "pattern": "^VK_DESCRIPTOR_TYPE_[A-Z0-9_]+$",
      "description": "Vulkan descriptor set type of the indexed input/output. Must follow Vulkan naming convention."
    },
    "^(input|output)_(0|[1-9]\\d*)_type$": {
      "type": "string",
      "description": "Resource type of the indexed input/output (e.g. Tensor, Image, Buffer)."
    },
    "^(input|output)_(0|[1-9]\\d*)_binding$": {
      "type": "integer",
      "minimum": 0,
      "description": "Binding id of the indexed input/output."
    },
    "^(input|output)_(0|[1-9]\\d*)_descriptorset$": {
      "type": "integer",
      "minimum": 0,
      "description": "Descriptor set index of the indexed input/output."
    },
    "^(input|output)_(0|[1-9]\\d*)_sampler$": {
      "$ref": "#/$defs/sampler_config"
    }
  },
  "required": [
    "entry_point",
    "workgroup_sizes"
  ],
  "additionalProperties": true
}
