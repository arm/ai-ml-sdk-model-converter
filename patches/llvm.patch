+    auto accType = convertAccType(adaptor.getAccType());
+    auto localBound = adaptor.getLocalBound();
+    Value input = adaptor.getInput();
+    Value weight = adaptor.getWeight();
+    Value bias = adaptor.getBias();
+    Value inputZp = adaptor.getInputZp();
